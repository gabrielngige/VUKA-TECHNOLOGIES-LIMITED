# ─── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development          # set to 'production' on the server

# ─── Frontend origin (CORS whitelist) ─────────────────────────
# Development:  http://localhost:5173
# Production:   https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ─── Auth ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ─── M-Pesa / Daraja API ──────────────────────────────────────
MPESA_ENV=sandbox             # change to 'production' when going live
# Get credentials from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# Public URL Safaricom will POST to after an STK push completes
# For local dev use ngrok: ngrok http 4000  → https://xxxx.ngrok.io/api/mpesa/callback
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback
